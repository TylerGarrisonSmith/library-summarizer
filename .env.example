# GCP auth — path to service account JSON (gitignored)
GOOGLE_APPLICATION_CREDENTIALS=./resource-summarizer-8b243a5a648a.json

# GCP project
GCP_PROJECT_ID=resource-summarizer

# BigQuery target
BIGQUERY_DATASET=summaries
BIGQUERY_TABLE=content_summaries

# RSS feed to scrape
FEED_URL=https://blog.fabric.microsoft.com/en-us/blog/feed/

# How many days back to look for new articles (match your run cadence)
LOOKBACK_DAYS=1

# Cost guards
MAX_ARTICLES_PER_RUN=25
MAX_TEXT_CHARS=15000

# Vertex AI
VERTEX_AI_REGION=us-central1
GEMINI_MODEL=gemini-1.5-flash
